{
  "version": 2,
  "builds": [
    { "src": "public/**/*", "use": "@vercel/static" }
  ],
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/about", "destination": "/About.html" },
    { "source": "/contact", "destination": "/Contact.html" },
    { "source": "/register", "destination": "/Register.html" },
    { "source": "/djangoapp/get_cars", "destination": "/CarsJson.html" },
    { "source": "/djangoapp/get_dealers", "destination": "/DealersJson.html" },
    { "source": "/djangoapp/dealer/KS", "destination": "/DealersByStateJson.html" },
    { "source": "/djangoapp/dealer/:id", "destination": "/DealerDetailJson.html" },
    { "source": "/djangoapp/reviews/dealer/:id", "destination": "/DealerReviewJson.html" },
    { "source": "/djangoapp/analyze/:text", "destination": "/SentimentJson.html" }
  ]
}
